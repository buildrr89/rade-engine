{
  "build": {
    "env": {
      "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1"
    }
  },
  "installCommand": "pip install -r requirements.txt && pip install -e .",
  "functions": {
    "api/gh/webhook.py": {
      "runtime": "@vercel/python@4.3.0",
      "maxDuration": 10,
      "memory": 512
    },
    "api/gh/analyze.py": {
      "runtime": "@vercel/python@4.3.0",
      "maxDuration": 300,
      "memory": 3008
    }
  }
}
