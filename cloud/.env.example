# RADE Cloud — environment variables
# Copy to .env.local for local dev (vercel dev reads this automatically).
# In production, set these via `vercel env add` or the Vercel dashboard.

# === Day 1 (required now) ===

# Shared secret between GitHub and the webhook handler. Must match the value
# set when the GitHub App was created. Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# === Day 2+ (required before queue + analysis land) ===

# Numeric GitHub App ID from the App settings page.
# GITHUB_APP_ID=

# GitHub App private key (PEM). Store with literal \n line breaks, OR paste the
# full multi-line PEM between triple quotes if your secret manager supports it.
# GITHUB_APP_PRIVATE_KEY=

# GitHub OAuth credentials for the dashboard "Sign in with GitHub" flow.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Neon Postgres connection string (via Vercel Marketplace).
# After provisioning, apply cloud/db/migrations/001_rade_webhook_runs.sql once.
# DATABASE_URL=

# Optional: URL of this project's /api/gh/analyze (or a queue consumer that
# forwards to it). Webhook POSTs {"run_id","github_delivery_id"} after insert.
# If unset, rows stay queued until something calls analyze (or you poll via
# run_store.claim_next_pr_analysis in a cron).
# RADE_QUEUE_ENQUEUE_URL=
# When set, analyze.py also requires the same value as Authorization: Bearer on
# POST (in addition to DATABASE_URL and GitHub App credentials for real API calls).
# RADE_QUEUE_ENQUEUE_TOKEN=

# Worker — same as action.yml (path is inside the target repo, not this service).
# RADE_INPUT_PATH=examples/sample_ios_output.json
# RADE_APP_ID=com.example.legacyapp
# RADE_FAIL_ON_REGRESSION=true
# RADE_FAIL_ON_AXE_REGRESSION=true

# Stripe keys. Use test-mode keys until you've had 3 sales calls.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Vercel Blob store (for persisted report artifacts).
# BLOB_READ_WRITE_TOKEN=
